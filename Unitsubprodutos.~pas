procedure Tfrmsubprodutos.DBGrid1TitleClick(Column: TColumn);
var
  I: Integer;
begin
  for I := 0 to DBGrid1.Columns.Count - 1 do
  DBGrid1.Columns[i].Title.Font.Style := [];
  dm.TSUBPRODUTOS.IndexFieldNames := Column.FieldName;
