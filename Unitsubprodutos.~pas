procedure Tfrmsubprodutos.expExit(Sender: TObject);
begin
if exp.Text = '0,000' then
begin
DM.TsubProdutos.edit;
DM.TSUBPRODUTOS['EXP']:='0,000';
bitbtn1.Click;
end
else
begin
if exp.Text > '0,50' then
begin
Application.MessageBox('Expessura informada invalido, Verifique!', 'Lançamento', mb_Ok + mb_IconInformation);
exp.SetFocus;
end
else
bitbtn1.SetFocus;
end
end;

procedure Tfrmsubprodutos.largExit(Sender: TObject);
begin
if larg.Text = '0,000' then
begin
DM.TsubProdutos.edit;
DM.TSUBPRODUTOS['LARG']:='0,000';
exit
end
else
begin
if larg.Text > '1,50' then
begin
Application.MessageBox('Largura informada invalido, Verifique!', 'Lançamento', mb_Ok + mb_IconInformation);
larg.SetFocus;
end
end
end;

procedure Tfrmsubprodutos.compExit(Sender: TObject);
begin
if comp.Text = '0,00' then
begin
DM.TsubProdutos.edit;
DM.TSUBPRODUTOS['COMP']:='0,00';
exit
end
else
begin
if comp.Text > '9,00' then
begin
Application.MessageBox('Comprimento informado invalido, Verifique!', 'Lançamento', mb_Ok + mb_IconInformation);
comp.SetFocus;
end
end
end;

